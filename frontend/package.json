{
  "name": "octopus-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "lint:dead": "knip",
    "audit:deps": "npm audit --audit-level=moderate",
    "format": "prettier --write \"src/**/*.{js,svelte,css,html}\" \"e2e/**/*.js\" \"*.{js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,svelte,css,html}\" \"e2e/**/*.js\" \"*.{js,json,html}\"",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "validate:patterns": "bash ../scripts/validate-patterns.sh",
    "validate": "npm run check && npm run lint && npm run lint:css && npm run format:check && npm run validate:patterns && npm run lint:dead && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/inter": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "dompurify": "^3.4.12",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.21.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "marked": "^18.0.6",
    "postcss": "^8.5.20",
    "postcss-html": "^1.8.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "stylelint": "^17.14.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
