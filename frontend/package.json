{
  "name": "octopus-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "lint:dead": "knip",
    "audit:deps": "npm audit --audit-level=high",
    "format": "prettier --write \"src/**/*.{js,svelte,css,html}\" \"e2e/**/*.js\" \"*.{js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,svelte,css,html}\" \"e2e/**/*.js\" \"*.{js,json,html}\"",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "validate:patterns": "bash ../scripts/validate-patterns.sh",
    "validate": "npm run check && npm run lint && npm run lint:css && npm run format:check && npm run validate:patterns && npm run lint:dead && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.56.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/svelte": "^5.2.9",
    "@tsconfig/svelte": "^5.0.6",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.22",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "knip": "^5.66.4",
    "postcss": "^8.5.10",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "stylelint": "^16.25.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^39.0.1",
    "svelte": "^5.39.6",
    "svelte-check": "^4.3.3",
    "svelte-eslint-parser": "^1.4.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vitest": "^3.2.4"
  }
}
