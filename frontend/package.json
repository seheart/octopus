{
  "name": "octopus-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.{css,svelte}\"",
    "lint:css:fix": "stylelint \"src/**/*.{css,svelte}\" --fix",
    "lint:dead": "knip",
    "audit:deps": "npm audit --audit-level=high",
    "format": "prettier --write \"src/**/*.{js,svelte,css,html}\" \"e2e/**/*.js\" \"*.{js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,svelte,css,html}\" \"e2e/**/*.js\" \"*.{js,json,html}\"",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "validate:patterns": "bash ../scripts/validate-patterns.sh",
    "validate": "npm run check && npm run lint && npm run lint:css && npm run format:check && npm run validate:patterns && npm run lint:dead && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/svelte": "^5.2.9",
    "@tsconfig/svelte": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "^10.4.22",
    "dompurify": "^3.4.5",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.12.4",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.2",
    "marked": "^18.0.4",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^4.0.1",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.39.6",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
